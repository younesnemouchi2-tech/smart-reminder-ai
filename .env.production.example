# ========================================
# متغيرات بيئة الإنتاج - Vercel
# ========================================
# انسخ هذه القيم إلى لوحة تحكم Vercel → Settings → Environment Variables

# 1. رابط قاعدة بيانات PostgreSQL (من Neon أو Supabase)
# مثال: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# 2. سر NextAuth (مهم جداً للأمان)
# لتوليد قيمة جديدة، شغّل في Terminal: openssl rand -base64 32
NEXTAUTH_SECRET=

# 3. رابط التطبيق (بعد النشر الأول، حدّثه بالدومين النهائي)
# للبداية استخدم: https://your-project.vercel.app
# بعد ربط دومين zad-plus-dz.com استخدم: https://zad-plus-dz.com
NEXTAUTH_URL=
