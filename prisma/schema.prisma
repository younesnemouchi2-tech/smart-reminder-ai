// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tasks         Task[]
  resetTokens   PasswordReset[]
  pushSubscriptions PushSubscription[]
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Task {
  id              String       @id @default(cuid())
  userId          String
  title           String
  description     String?
  status          String       @default("PENDING")
  priority        String       @default("MEDIUM")
  category        String       @default("general")
  dueDate         DateTime?
  suggestedTime   String?
  aiSuggestion    String?
  completedAt     DateTime?
  // Recurrence: NONE, DAILY, WEEKLY, MONTHLY
  recurrence      String       @default("NONE")
  recurrenceEnd   DateTime?
  // Track the original due date for recurrence calculations
  originalDueDate DateTime?
  // Track which reminders have been sent (for client-side reminder system)
  lastReminderSent DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dueDate])
}

model ProductivityLog {
  id          String   @id @default(cuid())
  userId      String
  taskTitle   String
  category    String
  priority    String
  completedAt DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
}

model UserSettings {
  id           String   @id @default("default")
  workStart    String   @default("09:00")
  workEnd      String   @default("17:00")
  breakTime    Int      @default(15)
  focusBlock   Int      @default(25)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String   @unique
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
